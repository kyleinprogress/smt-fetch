# Smart Meter Texas credentials — copy to .env and fill in
# Never commit this file to git.

SMT_USERNAME=your_smt_username@email.com
SMT_PASSWORD=your_smt_password
SMT_ESIID=your_esiid_from_electric_bill

# Output directory for CSV files (default: ./data next to smt_fetch.py)
# SMT_OUTPUT_DIR=/data/energy/smt

# How many days back to fetch. 1 = yesterday (default).
# Use 2 if running early in the morning before yesterday's data is ready.
SMT_DAYS_BACK=1

# Set to true to overwrite existing CSV files
# SMT_FORCE_REFETCH=false

# Log verbosity: DEBUG, INFO, WARNING, ERROR
SMT_LOG_LEVEL=INFO

# Location for weather data (Open-Meteo, free, no API key needed)
# Find your coordinates at https://www.latlong.net/
SMT_LATITUDE=29.7604
SMT_LONGITUDE=-95.3698

# Dashboard settings (all optional)
# SMT_DASH_PORT=8080
# SMT_DASH_HOST=0.0.0.0

# Time-of-use analysis windows (for battery sizing analysis)
# These define the "free electricity" window for TOU plan comparison
# SMT_FREE_START=21
# SMT_FREE_END=6
